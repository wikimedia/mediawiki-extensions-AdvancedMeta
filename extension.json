{
	"name": "AdvancedMeta",
	"version": "4.0.0-alpha",
	"author": [
		"[http://www.stephanmuller.nl Stephan Muller]",
		"Bart van Heukelom",
		"Zayoo",
		"Patric Wirth <wirth@hallowelt.com>",
		"[https://www.hallowelt.com Hallo Welt! GmbH]"
	],
	"url": "https://www.mediawiki.org/wiki/Extension:AdvancedMeta",
	"descriptionmsg": "advancedmeta-desc",
	"type": "other",
	"license-name": "GPL-3.0-only",
	"requires": {
		"MediaWiki": ">= 1.43.0"
	},
	"MessagesDirs": {
		"AdvancedMeta": [
			"i18n"
		]
	},
	"ServiceWiringFiles": [
		"includes/ServiceWiring.php"
	],
	"APIModules": {
		"advancedmeta-tasks": "\\AdvancedMeta\\Api\\Tasks"
	},
	"GroupPermissions": {
		"*": {
			"advancedmeta-edit": false
		},
		"user": {
			"advancedmeta-edit": false
		},
		"bureaucrat": {
			"advancedmeta-edit": true
		},
		"sysop": {
			"advancedmeta-edit": true
		}
	},
	"AvailableRights": [
		"advancedmeta-edit"
	],
	"config": {
		"GlobalKeywordsMsgKey": {
			"value": "globalkeywords"
		},
		"NoIndexOnOldVersions": {
			"value": false
		}
	},
	"config_prefix": "adwm",
	"ConfigRegistry": {
		"adwm": "\\AdvancedMeta\\Config::newInstance"
	},
	"AutoloadNamespaces": {
		"AdvancedMeta\\": "src/"
	},
	"Hooks": {
		"LoadExtensionSchemaUpdates": "runDatabaseUpdates",
		"BeforePageDisplay": [ "addResources", "applyMetaData" ],
		"SkinTemplateNavigation::Universal": "addLinks"
	},
	"HookHandlers": {
		"addLinks": {
			"class": "AdvancedMeta\\Hook\\SkinTemplateNavigationUniversal\\AddAdvancedMeta",
			"services": [ "PermissionManager" ]
		},
		"runDatabaseUpdates": {
			"class": "AdvancedMeta\\Hook\\LoadExtensionSchemaUpdates\\AddAdvancedMetaDBSchema"
		},
		"addResources": {
			"class": "AdvancedMeta\\Hook\\BeforePageDisplay\\AddResources",
			"services": [ "PermissionManager", "AdvancedMetaFactory" ]
		},
		"applyMetaData": {
			"class": "AdvancedMeta\\Hook\\BeforePageDisplay\\ApplyMetaData",
			"services": [ "AdvancedMetaFactory", "AdvancedMeta._Config" ]
		}
	},
	"ResourceFileModulePaths": {
		"localBasePath": "resources",
		"remoteExtPath": "AdvancedMeta/resources"
	},
	"ResourceModules": {
		"ext.advancedmeta": {
			"scripts": [
				"ext.advancedmeta.js"
			],
			"dependencies": [
				"mediawiki.api",
				"oojs",
				"oojs-ui"
			],
			"messages": [
				"advancedmeta-metasettings",
				"advancedmeta-titlealias",
				"advancedmeta-dialog-btn-label-save",
				"advancedmeta-dialog-btn-label-cancel",
				"advancedmeta-dialog-btn-label-delete",
				"advancedmeta-dialog-input-label-description",
				"advancedmeta-dialog-input-label-follow",
				"advancedmeta-dialog-input-label-index",
				"advancedmeta-dialog-input-label-keywords",
				"advancedmeta-dialog-input-help-keywords"
			]
		}
	},
	"manifest_version": 2
}
